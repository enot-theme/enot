{
  "slug": "enot",
  "ports": [
    {
      "app": "mc",
      "name": "Midnight Commander",
      "category": "file-manager",
      "kind": "module",
      "depth": "16M+256",
      "guarantee": "full",
      "outputs": [
        {
          "path": "mc/enot-dark-16M.ini"
        },
        {
          "path": "mc/enot-dark256.ini"
        },
        {
          "path": "mc/enot-light-16M.ini"
        },
        {
          "path": "mc/enot-light256.ini"
        }
      ]
    },
    {
      "app": "ranger",
      "name": "ranger",
      "category": "file-manager",
      "kind": "static",
      "depth": "ansi",
      "guarantee": "ansi",
      "outputs": [
        {
          "path": "ranger/colorschemes/enot.py"
        }
      ]
    },
    {
      "app": "vim",
      "name": "vim / neovim",
      "category": "editor",
      "kind": "module",
      "depth": "16M+256+ansi",
      "guarantee": "full",
      "outputs": [
        {
          "path": "vim/colors/enot.vim"
        }
      ]
    },
    {
      "app": "wezterm",
      "name": "WezTerm",
      "category": "terminal",
      "kind": "template",
      "depth": "16M",
      "guarantee": "full",
      "outputs": [
        {
          "theme": "dark",
          "path": "wezterm/enot-dark.toml"
        },
        {
          "theme": "light",
          "path": "wezterm/enot-light.toml"
        }
      ]
    }
  ]
}
