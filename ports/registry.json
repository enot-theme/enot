{
  "slug": "enot",
  "ports": [
    {
      "app": "lightline",
      "name": "lightline",
      "category": "statusline",
      "kind": "module",
      "depth": "16M+256",
      "guarantee": "full",
      "install": "copy into ~/.vim/autoload/lightline/colorscheme/ and set the lightline colorscheme to enot",
      "outputs": [
        {
          "path": "dist/lightline/autoload/lightline/colorscheme/enot.vim"
        }
      ]
    },
    {
      "app": "mc",
      "name": "Midnight Commander",
      "category": "file-manager",
      "kind": "module",
      "depth": "16M+256",
      "guarantee": "full",
      "install": "copy into ~/.local/share/mc/skins/ and select in Options > Appearance or mc -S enot-dark-16M",
      "outputs": [
        {
          "path": "dist/mc/enot-dark-16M.ini"
        },
        {
          "path": "dist/mc/enot-dark256.ini"
        },
        {
          "path": "dist/mc/enot-light-16M.ini"
        },
        {
          "path": "dist/mc/enot-light256.ini"
        }
      ]
    },
    {
      "app": "nimble",
      "name": "Nimble Commander",
      "category": "file-manager",
      "kind": "template",
      "depth": "16M",
      "guarantee": "full",
      "install": "import via Settings > Themes, then set both in automatic switching",
      "outputs": [
        {
          "theme": "dark",
          "path": "dist/nimble/enot-dark.json"
        },
        {
          "theme": "light",
          "path": "dist/nimble/enot-light.json"
        }
      ]
    },
    {
      "app": "ranger",
      "name": "ranger",
      "category": "file-manager",
      "kind": "static",
      "depth": "ansi",
      "guarantee": "ansi",
      "install": "copy into ~/.config/ranger/colorschemes/ and add \"set colorscheme enot\" to rc.conf; ranger >= 1.9.3",
      "outputs": [
        {
          "path": "dist/ranger/colorschemes/enot.py"
        }
      ]
    },
    {
      "app": "sublime",
      "name": "Sublime Text",
      "category": "editor",
      "kind": "template",
      "depth": "16M",
      "guarantee": "full",
      "install": "copy into Packages/User (Preferences > Browse Packages), then UI: Select Color Scheme",
      "outputs": [
        {
          "theme": "dark",
          "path": "dist/sublime/enot-dark.sublime-color-scheme"
        },
        {
          "theme": "light",
          "path": "dist/sublime/enot-light.sublime-color-scheme"
        }
      ]
    },
    {
      "app": "telegram",
      "name": "Telegram Desktop",
      "category": "messenger",
      "kind": "module",
      "depth": "16M",
      "guarantee": "full",
      "install": "Settings > Chat settings > Choose from file, or open the file in any chat",
      "outputs": [
        {
          "theme": "dark",
          "path": "dist/telegram/enot-dark.tdesktop-theme"
        },
        {
          "theme": "light",
          "path": "dist/telegram/enot-light.tdesktop-theme"
        }
      ]
    },
    {
      "app": "vim",
      "name": "vim / neovim",
      "category": "editor",
      "kind": "module",
      "depth": "16M+256+ansi",
      "guarantee": "full",
      "install": "copy into ~/.vim/colors/ or ~/.config/nvim/colors/",
      "outputs": [
        {
          "path": "dist/vim/colors/enot.vim"
        }
      ]
    },
    {
      "app": "vscode",
      "name": "VS Code",
      "category": "editor",
      "kind": "module",
      "depth": "16M",
      "guarantee": "full",
      "install": "code --install-extension enot.vsix, or Extensions > ... > Install from VSIX",
      "outputs": [
        {
          "path": "dist/vscode/enot.vsix"
        }
      ]
    },
    {
      "app": "wezterm",
      "name": "WezTerm",
      "category": "terminal",
      "kind": "template",
      "depth": "16M",
      "guarantee": "full",
      "install": "copy into ~/.config/wezterm/colors/ and set color_scheme = \"enot-dark\"",
      "outputs": [
        {
          "theme": "dark",
          "path": "dist/wezterm/enot-dark.toml"
        },
        {
          "theme": "light",
          "path": "dist/wezterm/enot-light.toml"
        }
      ]
    }
  ]
}
