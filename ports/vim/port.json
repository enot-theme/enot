{
  "app": "vim",
  "name": "vim / neovim",
  "category": "editor",
  "kind": "module",
  "depth": "16M+256+ansi",
  "guarantee": "full",
  "module": "render.py",
  "c256_pattern": "cterm[fb]g=(\\d+)",
  "outputs": [
    {"path": "vim/colors/enot.vim"}
  ],
  "install": "copy into ~/.vim/colors/ or ~/.config/nvim/colors/"
}
